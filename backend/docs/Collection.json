{
  "info": {
    "name": "Database Project API",
    "_postman_id": "12345678-abcd-efgh-ijkl-1234567890ab",
    "description": "Authentication and User Module APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "API_URL", "value": "http://localhost:3000" },
    { "key": "ACCESS_TOKEN", "value": "" },
    { "key": "REFRESH_TOKEN", "value": "" },
    { "key": "DEFAULT_USER_EMAIL", "value": "john@company.com" },
    { "key": "USER_ID", "value": "uuid-user" }
  ],
  "item": [
    {
      "name": "Auth Module",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@company.com\",\n  \"password\": \"Password123!\",\n  \"roleId\": \"uuid-role\",\n  \"departmentId\": \"uuid-department\",\n  \"region\": \"US\",\n  \"salary\": 5000\n}"
            },
            "url": "{{API_URL}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{DEFAULT_USER_EMAIL}}\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{API_URL}}/api/v1/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{REFRESH_TOKEN}}\"\n}"
            },
            "url": "{{API_URL}}/api/v1/auth/refresh-token"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{REFRESH_TOKEN}}\"\n}"
            },
            "url": "{{API_URL}}/api/v1/auth/logout"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": "{{API_URL}}/api/v1/auth/me"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"Password123!\",\n  \"newPassword\": \"NewPassword456!\"\n}"
            },
            "url": "{{API_URL}}/api/v1/auth/change-password"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{DEFAULT_USER_EMAIL}}\"\n}"
            },
            "url": "{{API_URL}}/api/v1/auth/forgot-password"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"uuid-reset-token\",\n  \"newPassword\": \"NewPassword456!\"\n}"
            },
            "url": "{{API_URL}}/api/v1/auth/reset-password"
          }
        }
      ]
    },
    {
      "name": "User Module",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ali Khan\",\n  \"email\": \"ali@company.com\",\n  \"roleId\": \"uuid-role\",\n  \"departmentId\": \"uuid-department\",\n  \"region\": \"PK\",\n  \"salary\": 1200\n}"
            },
            "url": "{{API_URL}}/api/v1/users"
          }
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": "{{API_URL}}/api/v1/users?page=1&limit=20"
          }
        },
        {
          "name": "Get Single Employee",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": "{{API_URL}}/api/v1/users/{{USER_ID}}"
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ali Updated\",\n  \"region\": \"PK\",\n  \"salary\": 1300\n}"
            },
            "url": "{{API_URL}}/api/v1/users/{{USER_ID}}"
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": "{{API_URL}}/api/v1/users/{{USER_ID}}"
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "url": "{{API_URL}}/api/v1/users/me"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ali Personal Update\",\n  \"region\": \"PK\"\n}"
            },
            "url": "{{API_URL}}/api/v1/users/me"
          }
        }
      ]
    }
  ]
}